# 复制为 deploy.env 并填写实际值: cp deploy.env.example deploy.env

# 阿里云 ECS 公网 IP
SERVER_HOST=your-server-ip

# SSH 用户名（通常为 root 或 ecs-user）
SERVER_USER=root

# SSH 端口
SERVER_PORT=22

# SSH 私钥路径（可选，留空则使用默认密钥或密码）
SSH_KEY=

# SSH 密码（密码登录时填写，建议使用 SSH 密钥更安全）
SSH_PASSWORD=

# 应用安装目录
APP_HOME=/opt/sqlbotai

# Spring 生产环境数据库密码（可选）
DB_PASSWORD=
